<footer class="footer">
    <div class="container">
        <div class="footer-inner">
            <div class="footer-logo">
                <img src="<%= site.logoEmblem %>?v=<%= assetVersion %>" alt="MJP Security" class="logo-img">
                <div>
                    <span class="logo-name">SECURITY</span>
                    <p class="footer-tagline"><%= site.tagline %></p>
                </div>
            </div>
            <div class="footer-nav">
                <a href="/">Home</a>
                <a href="/services/guarding">Guarding</a>
                <a href="/services/armed-response">Armed Response</a>
                <a href="/services/monitoring">Monitoring</a>
                <a href="/services/cctv">CCTV</a>
                <a href="/services">All Services</a>
                <a href="/about">About</a>
                <a href="/contact">Contact</a>
            </div>
            <div class="footer-contact">
                <a href="tel:<%= site.phoneHref %>"><i class="fas fa-phone"></i> <%= site.phoneDisplay %></a>
                <a href="<%= site.whatsappLink %>" target="_blank" rel="noopener noreferrer"><i class="fab fa-whatsapp"></i> <%= site.whatsappDisplay %></a>
                <a href="mailto:<%= site.email %>"><i class="fas fa-envelope"></i> <%= site.email %></a>
                <span><i class="fas fa-map-marker-alt"></i> <%= site.address %></span>
            </div>
        </div>
        <div class="footer-bottom">
            <p>Copyright &copy; <%= new Date().getFullYear() %> MJP Security. All rights reserved. Cape Town, South Africa.</p>
            <p class="footer-credit">Designed by <a href="https://virtuodesigns.co.za/" target="_blank" rel="noopener noreferrer">Virtuo Designs</a></p>
        </div>
    </div>
</footer>

<a href="<%= site.whatsappLink %>" class="whatsapp-fab" target="_blank" rel="noopener noreferrer" aria-label="Chat with MJP Security on WhatsApp">
    <i class="fab fa-whatsapp"></i>
</a>
